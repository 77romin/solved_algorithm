import java.util.Scanner;

class Solution {
	public static void main(String args[]) throws Exception {
		Scanner sc = new Scanner(System.in);
		int a = sc.nextInt();
        int b = sc.nextInt();
        
        int result = a-b;
        
        if(result>0 || result == -2) System.out.println("A");
        else System.out.println("B");
	}
}